    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://www.ninjachat.ai/developers",
          "icon": "gauge"
        },
        {
          "anchor": "Playground",
          "href": "https://www.ninjachat.ai/developers/playground",
          "icon": "play"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/ninjachat-black.svg",
    "dark": "/logo/ninjachat-white.svg",
    "size": 180
  },
  "navbar": {
    "links": [
      {
        "label": "NinjaChat",
        "href": "https://www.ninjachat.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.ninjachat.ai/developers/keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.ninjachat.ai"
    }
  },
  "api": {
    "baseUrl": "https://ninjachat.ai",
    "auth": {
      "method": "bearer"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    }
  }
}
