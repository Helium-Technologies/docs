{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NinjaChat API",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Models & Pricing",
            "pages": [
              "models",
              "pricing"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "chat",
              "image-generation",
              "video-generation",
              "search"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "error-handling",
              "rate-limits",
              "best-practices"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "openapi": "openapi.json",
            "pages": [
              "POST /api/v1/chat",
              "POST /api/v1/search",
              "POST /api/v1/images",
              "POST /api/v1/video",
              "GET /api/v1/video/status"
            ]
          },
          {
            "group": "Key Management",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/api-keys",
              "POST /api/api-keys",
              "DELETE /api/api-keys"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Playground",
          "href": "https://www.ninjachat.ai/api-playground",
          "icon": "play"
        },
        {
          "anchor": "All Models",
          "href": "https://www.ninjachat.ai/api-models",
          "icon": "microchip"
        },
        {
          "anchor": "Get API Key",
          "href": "https://www.ninjachat.ai/settings?tab=api",
          "icon": "key"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/ninjachat-black.svg",
    "dark": "/logo/ninjachat-white.svg",
    "size": 180
  },
  "navbar": {
    "links": [
      {
        "label": "NinjaChat",
        "href": "https://www.ninjachat.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://www.ninjachat.ai/settings?tab=api"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://www.ninjachat.ai"
    }
  },
  "api": {
    "baseUrl": "https://ninjachat.ai",
    "auth": {
      "method": "bearer"
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required",
      "prefill": true
    }
  }
}
