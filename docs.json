{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "NinjaChat API",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Chat",
            "pages": [
              "chat",
              "smart-routing",
              "compare",
              "batch",
              "sessions",
              "estimate"
            ]
          },
          {
            "group": "Other Endpoints",
            "pages": [
              "image-generation",
              "video-generation",
              "search"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "models",
              "pricing",
              "error-handling",
              "rate-limits",
              "best-practices"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Chat",
            "openapi": "openapi.json",
            "pages": [
              "POST /api/v1/chat"
            ]
          },
          {
            "group": "Power Features",
            "openapi": "openapi.json",
            "pages": [
              "POST /api/v1/compare",
              "POST /api/v1/batch",
              "POST /api/v1/estimate",
              "GET /api/v1/models"
            ]
          },
          {
            "group": "Sessions",
            "openapi": "openapi.json",
            "pages": [
              "POST /api/v1/sessions",
              "GET /api/v1/sessions/{id}",
              "DELETE /api/v1/sessions/{id}",
              "GET /api/v1/sessions/{id}/export"
            ]
          },
          {
            "group": "Media",
            "openapi": "openapi.json",
            "pages": [
              "POST /api/v1/search",
              "POST /api/v1/images",
              "POST /api/v1/video",
              "GET /api/v1/video/status"
            ]
          },
          {
            "group": "Key Management",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/api-keys",
              "POST /api/api-keys",
              "DELETE /api/api-keys"
            ]
          },
          {
            "group": "Billing & Usage",
            "openapi": "openapi.json",
            "pages": [
              "GET /api/api-keys/transactions",
              "GET /api/api-keys/logs"
            ]
          },
          {
            "group": "Models",
